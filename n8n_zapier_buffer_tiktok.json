    {
      "parameters": {
        "jsCode": "// Đọc đúng cấu trúc từ LangChain Gemini node\nvar rawText = $input.first().json.content?.parts?.[0]?.text || '';\nvar videoData = $('Find Pending + Build Prompt').first().json;\n\nif (!rawText) {\n  throw new Error('[Gemini Error] Không có text output.');\n}\n\n// Hàm chuyên dụng để xử lý link Google Drive sang Link tải trực tiếp\nfunction getDirectLink(url) {\n  if (url.includes('drive.google.com')) {\n    var match = url.match(/\\/d\\/(.+?)\\/(view|edit)/) || url.match(/id=(.+?)(&|$)/);\n    var fileId = match ? match[1] : url.split('/d/')[1]?.split('/')[0];\n    if (fileId) return \"https://drive.google.com/uc?export=download&id=\" + fileId;\n  }\n  return url;\n}\n\n// Xóa markdown code block\nrawText = rawText.replace(/```json\\s*/gi, '').replace(/```\\s*/gi, '').trim();\n\nvar aiContent = {\n  caption: 'Triết học không phải để đọc — mà để sống. 🌿',\n  hashtags: '#ATyPodcast #TrietHoc'\n};\n\ntry {\n  var parsed = JSON.parse(rawText);\n  if (parsed.caption) aiContent.caption = parsed.caption;\n  if (parsed.hashtags) aiContent.hashtags = parsed.hashtags;\n} catch(e) {}\n\nvar fullDesc = (aiContent.caption + '\\n\\n' + aiContent.hashtags).substring(0, 2200);\n\nreturn [{\n  json: {\n    // TỰ ĐỘNG CHUYỂN ĐỔI LINK TẠI ĐÂY\n    video_url: getDirectLink(videoData.video_url), \n    description: fullDesc,\n    caption: aiContent.caption,\n    hashtags: aiContent.hashtags,\n    row_index: videoData.row_index,\n    episode_id: videoData.episode_id,\n    title: videoData.title,\n    posted_at: new Date().toISOString()\n  }\n}];\n"
      },
