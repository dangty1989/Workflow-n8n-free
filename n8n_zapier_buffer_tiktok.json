    {
      "parameters": {
        "jsCode": "const rows = $input.all();\nconst activeVideo = rows[0]?.json;\n\n// Dùng đúng tên cột: output_video_url\nif (!activeVideo || !activeVideo.output_video_url) {\n  return [{ json: { found: false, video_url: '', row_index: 0 } }];\n}\n\nreturn [{\n  json: {\n    found: true,\n    video_url: activeVideo.output_video_url,  // ← Sửa ở đây\n    title: activeVideo.title || 'Video không tiêu đề',\n    philosophical_concept: activeVideo.philosophical_concept || '',\n    target_pain_point: activeVideo.target_pain_point || '',\n    voice_tone_style: activeVideo.voice_tone_style || '',\n    episode_id: activeVideo.episode_id || '',\n    row_index: activeVideo.row_number || activeVideo._rowNumber || 2\n  }\n}];\n"
      },
